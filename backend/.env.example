# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/inboxly_chat
MONGODB_USER=
MONGODB_PASSWORD=

# Server Configuration
PORT=5000
NODE_ENV=development
HOST=localhost

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:8000

# Redis Configuration (for real-time chat and caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# WordPress Integration
WP_API_URL=http://localhost:8000/wp-json
WP_PLUGIN_NAMESPACE=inboxly-chat/v1

# Email Configuration (optional, for notifications)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=

# Gmail configuration for test assessment email delivery
GMAIL_USER=
GMAIL_PASSWORD=
EMAIL_FROM=

# AWS S3 (optional, for file uploads)
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_S3_BUCKET=
AWS_REGION=

# Logging
LOG_LEVEL=debug
